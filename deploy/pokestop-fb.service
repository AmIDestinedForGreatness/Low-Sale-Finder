[Unit]
Description=Yujin's Pokestop - Facebook groups feed (fb_feed.py)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/low-sale-finder
ExecStart=/home/ubuntu/low-sale-finder/venv/bin/python fb_feed.py
Restart=always
RestartSec=30
StandardOutput=append:/home/ubuntu/low-sale-finder/logs/fb.log
StandardError=append:/home/ubuntu/low-sale-finder/logs/fb.log

[Install]
WantedBy=multi-user.target
