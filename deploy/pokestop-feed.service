[Unit]
Description=Yujin's Pokestop - Carousell feed (main.py --feed)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/low-sale-finder
ExecStart=/home/ubuntu/low-sale-finder/venv/bin/python main.py --feed
Restart=always
RestartSec=30
StandardOutput=append:/home/ubuntu/low-sale-finder/logs/feed.log
StandardError=append:/home/ubuntu/low-sale-finder/logs/feed.log

[Install]
WantedBy=multi-user.target
